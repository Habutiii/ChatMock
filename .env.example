# Port
PORT=9099

# Auth dir
CHATGPT_LOCAL_HOME=/app/data

# Optional bearer-token protection for every non-health request
# Send it as Authorization: Bearer <token> from clients
# Preferred persistent token file location:
# CHATMOCK_API_KEY_FILE=/app/data/security/api_tokens.txt
# File format: one token per line, lines starting with # are ignored
# If CHATMOCK_API_KEY_FILE is unset, ChatMock will also look for:
# /app/data/security/api_tokens.txt

# Failed-auth protection
# CHATMOCK_AUTH_BLACKLIST_ATTEMPTS=10
# CHATMOCK_AUTH_WINDOW_SECONDS=300
# CHATMOCK_AUTH_BLACKLIST_PATH=/app/data/security/ip_blacklist.json

# show request/stream logs
VERBOSE=false

# OAuth client id (modify only if you know what you're doing)
# CHATGPT_LOCAL_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# Reasoning controls
CHATGPT_LOCAL_REASONING_EFFORT=medium       # none|minimal|low|medium|high|xhigh
CHATGPT_LOCAL_REASONING_SUMMARY=auto        # auto|concise|detailed|none
CHATGPT_LOCAL_REASONING_COMPAT=think-tags   # legacy|o3|think-tags|current
CHATGPT_LOCAL_EXPOSE_REASONING_MODELS=false

# Enable default web search tool
CHATGPT_LOCAL_ENABLE_WEB_SEARCH=false

# Force a specific model name
# CHATGPT_LOCAL_DEBUG_MODEL=gpt-5.4
